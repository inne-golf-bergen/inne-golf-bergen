{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/vilkar/layout,_N_T_/[lang]/vilkar/page,_N_T_/no/vilkar"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/vilkar/__PAGE__",
    "/$d$lang/vilkar",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}