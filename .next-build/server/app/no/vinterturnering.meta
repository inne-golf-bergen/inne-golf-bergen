{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/vinterturnering/layout,_N_T_/[lang]/vinterturnering/page,_N_T_/no/vinterturnering"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/vinterturnering/__PAGE__",
    "/$d$lang/vinterturnering",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}