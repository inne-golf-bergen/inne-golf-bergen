{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/bedrift/layout,_N_T_/[lang]/bedrift/page,_N_T_/en/bedrift"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/bedrift/__PAGE__",
    "/$d$lang/bedrift",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}