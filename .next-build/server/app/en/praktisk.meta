{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/praktisk/layout,_N_T_/[lang]/praktisk/page,_N_T_/en/praktisk"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/praktisk/__PAGE__",
    "/$d$lang/praktisk",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}