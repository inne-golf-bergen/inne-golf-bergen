{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/gavekort/layout,_N_T_/[lang]/gavekort/page,_N_T_/en/gavekort"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/gavekort/__PAGE__",
    "/$d$lang/gavekort",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}