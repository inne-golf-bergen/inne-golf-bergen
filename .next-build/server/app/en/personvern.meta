{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/personvern/layout,_N_T_/[lang]/personvern/page,_N_T_/en/personvern"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/personvern/__PAGE__",
    "/$d$lang/personvern",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}