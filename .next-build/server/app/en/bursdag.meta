{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/bursdag/layout,_N_T_/[lang]/bursdag/page,_N_T_/en/bursdag"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/bursdag/__PAGE__",
    "/$d$lang/bursdag",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}