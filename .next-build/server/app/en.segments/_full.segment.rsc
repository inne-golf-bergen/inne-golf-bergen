15:T504,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What does it cost?","acceptedAnswer":{"@type":"Answer","text":"100–200 kr per 30 minutes per bay, depending on time and venue. The price covers the whole bay — up to six of you."}},{"@type":"Question","name":"Do I need my own gear?","acceptedAnswer":{"@type":"Answer","text":"No. Free loaner clubs, balls and tees at both venues — men’s, women’s and junior."}},{"@type":"Question","name":"How many can we bring?","acceptedAnswer":{"@type":"Answer","text":"Up to six people per bay."}},{"@type":"Question","name":"When are you open?","acceptedAnswer":{"@type":"Answer","text":"24/7, all week. You get access after booking."}},{"@type":"Question","name":"Can beginners play?","acceptedAnswer":{"@type":"Answer","text":"Yes. Beginners are welcome, and gear in every size is included."}},{"@type":"Question","name":"Is there parking?","acceptedAnswer":{"@type":"Answer","text":"Free parking at both venues. Åsane has its own spots; in Sandviken you park free right outside, 24/7."}},{"@type":"Question","name":"What do members get?","acceptedAnswer":{"@type":"Answer","text":"Annual membership is 1 800 kr and gives a 2 800 kr voucher for free booking, plus −20 % on all hours."}}]}5:["$","main",null,{"children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$15"}}],["$","section",null,{"id":"top","className":"page-module__O9ZbMG__hero","children":[["$","div",null,{"aria-hidden":"true","className":"page-module__O9ZbMG__heroBg","children":[["$","$L16",null,{"src":"/uploads/vg3_explainer_short_optimized_v3.mp4","webmSrc":"/uploads/vg3_explainer_short_optimized_v3.webm","mobileSrc":"/uploads/vg3_explainer_short_mobile_optimized_v3.mp4","mobileWebmSrc":"/uploads/vg3_explainer_short_mobile_optimized_v3.webm","className":"page-module__O9ZbMG__heroVideo"}],["$","div",null,{"className":"page-module__O9ZbMG__heroGradV"}],["$","div",null,{"className":"page-mod