15:T557,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Hva koster det å spille?","acceptedAnswer":{"@type":"Answer","text":"100–200 kr per 30 minutter per bay, avhengig av tidspunkt og senter. Prisen gjelder hele bayen — dere kan være opptil seks."}},{"@type":"Question","name":"Trenger jeg eget utstyr?","acceptedAnswer":{"@type":"Answer","text":"Nei. Gratis lånekøller, baller og tees ligger klare i begge sentre — herre, dame og junior."}},{"@type":"Question","name":"Hvor mange kan vi være?","acceptedAnswer":{"@type":"Answer","text":"Opptil seks personer per bay."}},{"@type":"Question","name":"Når har dere åpent?","acceptedAnswer":{"@type":"Answer","text":"Hele døgnet, hele uka. Du får adgang etter booking."}},{"@type":"Question","name":"Kan nybegynnere spille?","acceptedAnswer":{"@type":"Answer","text":"Ja. Nybegynnere er velkomne, og utstyr i alle størrelser er inkludert."}},{"@type":"Question","name":"Er det parkering?","acceptedAnswer":{"@type":"Answer","text":"Gratis parkering ved begge sentre. Åsane har egne plasser; i Sandviken parkerer du gratis rett utenfor, hele døgnet."}},{"@type":"Question","name":"Hva får jeg som medlem?","acceptedAnswer":{"@type":"Answer","text":"Årsmedlemskap koster 1 800 kr og gir et verdikort på 2 800 kr til fri booking, pluss −20 % på alle timer."}}]}5:["$","main",null,{"children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$15"}}],["$","section",null,{"id":"top","className":"page-module__O9ZbMG__hero","children":[["$","div",null,{"aria-hidden":"true","className":"page-module__O9ZbMG__heroBg","children":[["$","$L16",null,{"src":"/uploads/vg3_explainer_short_optimized_v3.mp4","webmSrc":"/uploads/vg3_explainer_short_optimized_v3.webm","mobileSrc":"/uploads/vg3_explainer_short_mobile_optimized_v3.mp4","mobileWebmSrc":"/uploads/vg3_explainer_short_mobile_optimized_v3.webm","className":"page-module__O9ZbMG__heroVideo"}],["$","div",null,{"className":"